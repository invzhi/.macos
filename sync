#!/bin/sh

# zsh
ln -f zprofile ~/.zprofile

# gitconfig
ln -f gitconfig ~/.gitconfig

# nvim
mkdir -p ~/.config/nvim
ln -f nvim.vim ~/.config/nvim/init.vim

# ghostty
mkdir -p ~/.config/ghostty
ln -f ghostty.conf ~/.config/ghostty/config

# zed
mkdir -p ~/.config/zed
ln -f zed/settings.json ~/.config/zed/settings.json
ln -f zed/keymap.json ~/.config/zed/keymap.json
